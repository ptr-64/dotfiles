snippet fqup "frequently used packages" "snip.line==0 and snip.column==3" e
% first declare the document class and other meta information
\documentclass{$1}
\author{ $2}
\date{ $3}
\title{ $4}

% Now for some packages for text input
\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage[english]{babel}
\usepackage{graphicx}
\usepackage{url}
\usepackage{float}
\usepackage{booktabs}
\usepackage{enumitem}

% and some packages for math
\usepackage{siunitx}
\sisetup{locale = US}

\usepackage{mathtools, amsmath, amsfonts, amsthm, assymb}

%finally some miscellaneous packages
\usepackge{todonotes}
% Give the paragraphs some room to breathe
\usepackage{parskip}

% Import svg files for rendering plots
\usepackage{import}
\usepackage{xifthen}
\usepackage{pdfpages}
\usepackage{transparent}
% for including images
\newcommand{\incfig}[1]{%
    \def\svgwidth{\columnwidth}
    \import{./figures/}{#1.pdf_tex}
}

% add a few macros 
\DeclareMathOperator*{\argmax}{argmax}
\DeclareMathOperator*{\argmin}{argmin}

% add fancy contradition symbol
\usepackage{stmaryrd} % for \lightning
\newcommand\contra{\scalebox{1.5}{$\lightning$}}

% a few easy shortcuts
\newcommand\N{\ensuremath{\mathbb{N}}}
\newcommand\R{\ensuremath{\mathbb{R}}}
\newcommand\Z{\ensuremath{\mathbb{Z}}}
\renewcommand\O{\ensuremath{\emptyset}}
\newcommand\Q{\ensuremath{\mathbb{Q}}}
\newcommand\C{\ensuremath{\mathbb{C}}}

% use a fancy header if you like:
% \usepackage{fancyhdr}
% \pagestyle{fancy}
% 
% LE: left even
% RO: right odd
% CE, CO: center even, center odd
% My name 
% \fancyhead[LE,RO]{Peter Iyer}
% 
% \fancyhead[RO,LE]{UGA} % Right odd,  Left even
% \fancyhead[RE,LO]{}          % Right even, Left odd
% 
% \fancyfoot[RO,LE]{\thepage}  % Right odd,  Left even
% \fancyfoot[RE,LO]{}          % Right even, Left odd
% \fancyfoot[C]{\leftmark}     % Center
% 
% \makeatother

% for economics (work in progress)
% \DelcareMathOperator{\ngmdt}{}

% Aaaand begin!
\begin{document}
\maketitle
$0


\end{document}
endsnippet

