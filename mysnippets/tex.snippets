snippet glbl "frequently used packages"
\documentclass{$1}
\author{ $2}
\date{ $3}
\title{ $4}
\usepackage{amsmath}
\usepackage{amsfonts}
\usepackage[utf8]{inputenc}
\usepackage{amssymb}
\usepackage{graphicx}
\usepackage{parskip}
\usepackage{import}
\usepackage{xifthen}
\usepackage{pdfpages}
\usepackage{transparent}
% for including images
\newcommand{\incfig}[1]{%
    \def\svgwidth{\columnwidth}
    \import{./figures/}{#1.pdf_tex}
}
\begin{document}
\maketitle
$0


\end{document}
endsnippet

